# ──────────────────────────────────────────────
# RepoBuddy Environment Configuration
# Copy to .env and adjust for your environment.
# ──────────────────────────────────────────────

# ── App ──
APP_ENV=development            # development | production
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true                 # MUST be false in production

# Comma-separated list of allowed origins for CORS.
# In production, restrict this to your real frontend origin(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──
DATABASE_URL=postgresql+asyncpg://repobuddy:repobuddy@localhost:5432/repobuddy
DATABASE_URL_SYNC=postgresql://repobuddy:repobuddy@localhost:5432/repobuddy

# ── Redis / Celery ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── File Upload ──
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads
REPOS_DIR=./repos

# ── GitHub ──
# Optional default token for private-repo clones. Users can also
# provide a per-request token from the UI.
GITHUB_TOKEN=

# ── AI / LLM ──
# Leave blank to disable AI features. Analysis still works fully without this.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── Frontend build-time ──
# Used by the Vite build. In docker-compose this is already set to
# http://backend:8000/api for container-to-container proxying.
VITE_API_URL=http://localhost:8000/api
