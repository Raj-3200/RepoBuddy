# ──────────────────────────────────────────────
# RepoBuddy Environment Configuration
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://repobuddy:repobuddy@localhost:5432/repobuddy
DATABASE_URL_SYNC=postgresql://repobuddy:repobuddy@localhost:5432/repobuddy

# Redis
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000

# File Upload
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads
REPOS_DIR=./repos

# GitHub
GITHUB_TOKEN=

# AI / LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
